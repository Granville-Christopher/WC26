# Copy to .env.local and fill in your values (never commit .env.local)

# Admin login & support contact
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=your-secure-password
ADMIN_SECRET=generate-a-long-random-string

# Optional: FIFA partner / affiliate ticket checkout URL
NEXT_PUBLIC_FIFA_TICKET_URL=https://www.fifa.com/fifaplus/en/tickets

# Optional: public site URL (production)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Vercel Blob (required on Vercel for persistent admin data + QR uploads)
# Create a Blob store in Vercel → Storage → Blob, then link it to this project.
# Vercel auto-adds BLOB_READ_WRITE_TOKEN when linked.
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
